{
    "instances": [
    <% it.instances.forEach(function(inst, i){ %>
        {
            "type": "<%= inst.classifierName %>",
            "name": "<%= inst.name %>",
            "properties": {
            <% (inst.slots||[]).forEach(function(slot, j){ %>
                "<%= slot.featureName %>": "<%= slot.value %>"<%= j < (inst.slots||[]).length - 1 ? ',' : '' %>
            <% }) %>
            }
        }<%= i < it.instances.length - 1 ? ',' : '' %>
    <% }) %>
    ]
}
